#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if command -v python3 >/dev/null 2>&1; then
    python_cmd=python3
else
    python_cmd=python
fi

if ! command -v clang-format >/dev/null 2>&1; then
    echo "pre-push: clang-format is required for formatting checks" >&2
    exit 1
fi

echo "pre-push: checking C++ formatting"
"$python_cmd" scripts/check-format.py
