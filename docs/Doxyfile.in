PROJECT_NAME           = "Volt"
PROJECT_BRIEF          = "A modern electronics design kernel"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@VOLT_DOXYGEN_OUTPUT_DIR@"
INPUT                  = @VOLT_DOXYGEN_INPUT_DIRS@
RECURSIVE              = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = @PROJECT_SOURCE_DIR@/README.md

FILE_PATTERNS          = *.hpp *.md
EXTENSION_MAPPING      = hpp=C++
